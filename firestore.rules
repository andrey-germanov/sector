rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Правила для коллекции feedback
    match /feedback/{feedbackId} {
      // Разрешаем создание (запись) для всех
      // Минимальная валидация - только проверка типов основных полей
      allow create: if request.resource.data.telegramNick is string
                   && request.resource.data.message is string
                   && request.resource.data.telegramNick.size() > 0
                   && request.resource.data.message.size() > 0
                   && request.resource.data.telegramNick.size() <= 100
                   && request.resource.data.message.size() <= 5000;
      
      // Разрешаем чтение для всех (защита на уровне приложения через пароль)
      allow read: if true;
      
      // Запрещаем обновление и удаление для всех
      allow update, delete: if false;
    }
    
    // Правила для коллекции tripSurvey
    match /tripSurvey/{surveyId} {
      allow create: if request.resource.data.city is string
                   && request.resource.data.city.size() > 0
                   && request.resource.data.city.size() <= 200
                   && request.resource.data.budgetFrom is string
                   && request.resource.data.budgetTo is string
                   && request.resource.data.suggestedLocation is string
                   && request.resource.data.suggestedLocation.size() <= 500
                   && request.resource.data.canJuly is string
                   && request.resource.data.expectations is string
                   && request.resource.data.expectations.size() <= 200
                   && request.resource.data.wishes is string
                   && request.resource.data.wishes.size() <= 200
                   && request.resource.data.suggestions is string
                   && request.resource.data.suggestions.size() <= 200;

      allow read: if true;
      allow update, delete: if false;
    }

    // Правила для коллекции sectorTripBooking (Sector Trip 2026)
    match /sectorTripBooking/{bookingId} {
      allow create: if request.resource.data.telegram is string
                   && request.resource.data.telegram.size() > 0
                   && request.resource.data.telegram.size() <= 100
                   && request.resource.data.fullName is string
                   && request.resource.data.fullName.size() > 0
                   && request.resource.data.fullName.size() <= 200
                   && request.resource.data.age is string
                   && request.resource.data.age.size() <= 5
                   && request.resource.data.sector is string
                   && request.resource.data.sector.size() <= 100
                   && request.resource.data.departureCity is string
                   && request.resource.data.departureCity.size() <= 100
                   && request.resource.data.departureGroup is string
                   && request.resource.data.tripDates is string
                   && request.resource.data.roomType is string
                   && request.resource.data.roommateTelegram is string
                   && request.resource.data.roommateTelegram.size() <= 200
                   && request.resource.data.activities is list
                   && request.resource.data.activitiesOther is string
                   && request.resource.data.activitiesOther.size() <= 300
                   && request.resource.data.helpOrganize is list
                   && request.resource.data.helpOrganizeOther is string
                   && request.resource.data.helpOrganizeOther.size() <= 300
                   && request.resource.data.willPay is string
                   && request.resource.data.paymentNotes is string
                   && request.resource.data.paymentNotes.size() <= 300;

      allow read: if true;
      allow update, delete: if false;
    }

    // Блокируем все остальные коллекции
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
